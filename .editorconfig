root = true

# Be consistent for shell and python scripts, with or without file extensions.
[*]
charset = utf-8
indent_style = space
indent_size = 4
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true

[{Makefile*,*.mk,*.go,.git{{/,}config,modules}*}]
indent_style = tab
tab_width = 8

[*.{json,yaml,yml,toml,xml,html,css,hcl,tf{,vars,state*}}{,.j2,_,~}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
